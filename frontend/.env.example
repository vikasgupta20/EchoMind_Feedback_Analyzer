# EchoMind AI - Frontend Configuration
# Copy this file to .env.local and fill in your values

# Backend API URL (only needed if backend is on different domain)
# For local development, leave empty (uses /api proxy)
# For production: https://your-backend-api.com (or .../api)
# The frontend auto-appends /api if you provide only the domain.
VITE_API_URL=
