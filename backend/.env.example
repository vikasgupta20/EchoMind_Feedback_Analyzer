# EchoMind AI - Backend Configuration
# Copy this file to .env and fill in your actual values

# Server Configuration
PORT=5000

# Gemini API Keys (get from https://aistudio.google.com/apikey)
# Add multiple keys for rotation and rate limit handling
GEMINI_API_KEY_1=your_api_key_1_here
GEMINI_API_KEY_2=your_api_key_2_here
GEMINI_API_KEY_3=your_api_key_3_here

# Frontend URL (for CORS if backend and frontend are on different domains)
FRONTEND_URL=http://localhost:5173
